---
import { mapRegions } from "../../data/mapRegions";
import "leaflet/dist/leaflet.css";
import "../../styles/global.css";
import "../../styles/map.css";
import "../../styles/map-player.css";

export function getStaticPaths() {
  return mapRegions.map((region) => ({
    params: { region: region.slug },
    props: { region },
  }));
}

const { region } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{region.title} | ExtreTiempo</title>
    <meta name="description" content={region.subtitle} />
  </head>
  <body>
    <main class="app-shell map-shell" data-region={JSON.stringify(region)}>
      <header class="site-header">
        <a class="brand brand--header" href="/" aria-label="ExtreTiempo inicio">
          <span class="brand__mark">ET</span>
          <span>
            <span class="eyebrow">Mapas meteorologicos</span>
            <span class="brand__name">{region.title}</span>
            <span class="meta" data-map-status>Cargando ciudades</span>
          </span>
        </a>
        <div class="site-header__actions">
          <a class="link-button" href="/">Inicio</a>
          <button
            class="hamburger"
            type="button"
            aria-label="Abrir menu"
            aria-expanded="false"
            data-menu-button
          >
            <span class="hamburger__lines" aria-hidden="true">
              <span></span>
              <span></span>
              <span></span>
            </span>
          </button>
        </div>
        <nav class="menu-panel is-hidden" aria-label="Menu principal" data-menu-panel>
          <a href="/">Inicio</a>
          {mapRegions.map((item) => <a href={`/mapas/${item.slug}/`}>Mapa {item.shortTitle}</a>)}
        </nav>
      </header>

      <section class="map-hero" aria-labelledby="map-title">
        <div>
          <p class="eyebrow">Leaflet + Open-Meteo</p>
          <h1 id="map-title">{region.title}</h1>
          <p class="meta">{region.subtitle}</p>
        </div>
        <div class="map-tabs" aria-label="Cambiar mapa">
          {
            mapRegions.map((item) => (
              <a href={`/mapas/${item.slug}/`} aria-current={region.slug === item.slug ? "page" : undefined}>
                {item.shortTitle}
              </a>
            ))
          }
        </div>
      </section>

      <section class="map-panel" aria-label={`Mapa meteorologico de ${region.title}`} data-map-panel>
        <div class="map-toolbar map-toolbar--player">
          <button class="play-button" type="button" data-play aria-pressed="false" disabled>
            <span aria-hidden="true" data-play-icon>▶</span>
            <span data-play-label>Play</span>
          </button>
          <div class="map-timeline">
            <div class="map-time-row">
              <strong data-time-label>Ahora</strong>
              <span class="map-day-badge" data-daylight-label>Día</span>
            </div>
            <label class="timeline-control">
              <span class="sr-only">Avanzar la prevision horaria del mapa</span>
              <input
                class="timeline-range"
                type="range"
                min="0"
                max="0"
                value="0"
                step="0.01"
                data-timeline
                disabled
              />
            </label>
            <p class="meta">
              <span data-progress-label>Esperando datos</span>
              <span aria-hidden="true"> · </span>
              <span>arrastra la barra para avanzar manualmente</span>
            </p>
          </div>
        </div>
        <div class="map-stage is-day" data-map-stage>
          <div id="weather-map" class="weather-map"></div>
          <div class="map-clock" aria-live="polite">
            <span data-clock-day>Hoy</span>
            <strong data-clock-time>Ahora</strong>
            <span data-clock-summary>Prevision horaria</span>
          </div>
        </div>
      </section>

      <section class="section" aria-labelledby="map-cities-title">
        <div class="section__header">
          <div>
            <h2 class="section__title" id="map-cities-title">Localidades del mapa</h2>
            <p class="meta">Pulsa una localidad para ver su detalle. Los datos se actualizan con la misma hora del reproductor.</p>
          </div>
        </div>
        <div class="panel list" data-map-list>
          <p class="state">Cargando datos de Open-Meteo</p>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>ExtreTiempo</strong>
        <p>Mapas con Leaflet y datos horarios de Open-Meteo. La animacion usa la prevision horaria disponible.</p>
      </div>
      <nav aria-label="Enlaces de pie">
        {mapRegions.map((item) => <a href={`/mapas/${item.slug}/`}>{item.shortTitle}</a>)}
        <a href="https://leafletjs.com/" target="_blank" rel="noreferrer">Leaflet</a>
      </nav>
    </footer>

    <script>
      import L from "leaflet";
      import {
        buildForecastUrl,
        buildGenericLocationHref,
        formatDay,
        formatHour,
        formatPercent,
        formatSpeed,
        formatTemperature,
        normalizeForecast,
        weatherStateForCode,
      } from "../../lib/weather";

      const PLAYER_HOUR_MS = 2600;
      const TIMELINE_PRECISION = 100;

      const root = document.querySelector("[data-region]");
      const region = JSON.parse(root?.getAttribute("data-region") ?? "{}");
      const status = document.querySelector("[data-map-status]");
      const playButton = document.querySelector("[data-play]");
      const playIcon = document.querySelector("[data-play-icon]");
      const playLabel = document.querySelector("[data-play-label]");
      const timeLabel = document.querySelector("[data-time-label]");
      const daylightLabel = document.querySelector("[data-daylight-label]");
      const progressLabel = document.querySelector("[data-progress-label]");
      const timeline = document.querySelector("[data-timeline]");
      const stage = document.querySelector("[data-map-stage]");
      const clockDay = document.querySelector("[data-clock-day]");
      const clockTime = document.querySelector("[data-clock-time]");
      const clockSummary = document.querySelector("[data-clock-summary]");
      const list = document.querySelector("[data-map-list]");
      const menuButton = document.querySelector("[data-menu-button]");
      const menuPanel = document.querySelector("[data-menu-panel]");

      let map;
      let playing = false;
      let animationId = 0;
      let lastAnimationTime = 0;
      let framePosition = 0;
      let frameCount = 0;
      let places = [];

      menuButton?.addEventListener("click", () => {
        const isOpen = menuButton.getAttribute("aria-expanded") === "true";
        menuButton.setAttribute("aria-expanded", String(!isOpen));
        menuPanel?.classList.toggle("is-hidden", isOpen);
      });

      playButton?.addEventListener("click", () => {
        setPlaying(!playing);
      });

      timeline?.addEventListener("input", (event) => {
        const value = Number(event.target.value);
        if (!Number.isFinite(value)) return;
        setPlaying(false);
        updateFrame(value);
      });

      window.addEventListener("storage", (event) => {
        if (region.source === "favorites" && event.key === "extretiempo:favorites") {
          loadForecasts();
        }
      });

      init();

      async function init() {
        try {
          map = L.map("weather-map", {
            zoomControl: true,
            scrollWheelZoom: true,
          }).setView(region.center, region.zoom);

          L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
            attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 18,
          }).addTo(map);

          window.requestAnimationFrame(() => map.invalidateSize());
          window.addEventListener("resize", () => map.invalidateSize());

          await loadForecasts();
        } catch (error) {
          showMapError();
        }
      }

      async function loadForecasts() {
        setPlaying(false);
        clearPlaces();
        const mapLocations = getMapLocations();

        if (mapLocations.length === 0) {
          setControlsDisabled(true);
          if (status) {
            status.textContent = region.source === "favorites"
              ? "Sin favoritos guardados"
              : "Sin localidades configuradas";
          }
          if (list) {
            list.innerHTML = region.source === "favorites"
              ? '<p class="state">Aun no tienes favoritos. Guarda municipios desde la busqueda o desde una pagina de localidad para verlos aqui.</p>'
              : '<p class="state">Este mapa no tiene localidades configuradas.</p>';
          }
          updateFrame(0);
          return;
        }

        if (status) status.textContent = `Cargando ${mapLocations.length} localidades`;
        if (list) list.innerHTML = '<p class="state">Cargando datos de Open-Meteo</p>';

        const results = await Promise.allSettled(
          mapLocations.map(async (city) => {
            const response = await fetch(buildForecastUrl(city));
            if (!response.ok) throw new Error(`No se pudo cargar ${city.name}`);
            return { city, forecast: normalizeForecast(city, await response.json()) };
          }),
        );

        places = results
          .filter((result) => result.status === "fulfilled")
          .map((result) => result.value);

        if (places.length === 0) {
          throw new Error("No se pudo cargar ninguna localidad");
        }

        frameCount = getFrameCount();
        configureTimeline(frameCount);

        places.forEach((place) => {
          const point = createFramePoint(place, framePosition);
          place.marker = L.marker([place.city.latitude, place.city.longitude], {
            icon: createMarkerIcon(place, point),
            keyboard: true,
            title: place.city.name,
          }).addTo(map);
          place.marker.bindPopup(createPopup(place, point));
        });

        fitMapToPlaces();
        renderCityList();
        updateFrame(framePosition);
        setControlsDisabled(frameCount <= 1);

        if (status) {
          const failed = results.length - places.length;
          status.textContent = failed
            ? `${places.length} localidades cargadas, ${failed} sin datos`
            : `${places.length} localidades cargadas`;
        }
      }

      function getMapLocations() {
        if (region.source === "favorites") {
          return getFavorites().map(normalizeFavoriteLocation).filter(Boolean);
        }
        return (region.cities ?? []).map((city) => ({
          ...city,
          id: `static-${city.slug}`,
          href: buildGenericLocationHref(city),
        }));
      }

      function normalizeFavoriteLocation(location) {
        if (!location?.name || !location?.latitude || !location?.longitude) return null;
        const slug = location.slug || location.id || slugify(location.name);
        const normalized = {
          id: location.id || `favorite-${slug}`,
          slug,
          name: location.name,
          province: location.province || "Favorito",
          latitude: Number(location.latitude),
          longitude: Number(location.longitude),
        };
        return {
          ...normalized,
          href: location.href || buildGenericLocationHref(normalized),
        };
      }

      function animate(timestamp) {
        if (!playing || frameCount <= 1) return;
        if (!lastAnimationTime) lastAnimationTime = timestamp;

        const elapsed = timestamp - lastAnimationTime;
        lastAnimationTime = timestamp;
        const maxFrame = Math.max(frameCount - 1, 0);
        const nextPosition = framePosition + elapsed / PLAYER_HOUR_MS;

        updateFrame(nextPosition > maxFrame ? 0 : nextPosition);
        animationId = window.requestAnimationFrame(animate);
      }

      function updateFrame(position) {
        const safePosition = roundTimelineValue(clamp(position, 0, Math.max(frameCount - 1, 0)));
        framePosition = safePosition;

        places.forEach((place) => {
          if (!place.marker) return;
          const point = createFramePoint(place, safePosition);
          updateMarkerElement(place, point);
          place.marker.setPopupContent(createPopup(place, point));
        });

        const sample = createFramePoint(places[0], safePosition);
        updateTimelineUi(sample, safePosition);
        updateMapListFrame(safePosition);
      }

      function updateTimelineUi(sample, position) {
        const maxFrame = Math.max(frameCount - 1, 0);
        const progress = maxFrame <= 0 ? 0 : (position / maxFrame) * 100;

        if (timeline) {
          timeline.value = String(position);
          timeline.style.setProperty("--progress", `${progress}%`);
        }

        const timeText = sample ? formatFullDate(sample.time) : "Ahora";
        const dayText = sample ? formatDay(sample.time, true) : "Hoy";
        const hourText = sample ? formatHour(sample.time) : "Ahora";
        const night = isNightFrame(sample);

        if (timeLabel) timeLabel.textContent = timeText;
        if (daylightLabel) daylightLabel.textContent = night ? "Noche" : "Día";
        if (progressLabel) {
          progressLabel.textContent = frameCount > 1
            ? `Avance ${Math.round(progress)}% de la prevision`
            : "Datos horarios no disponibles";
        }
        if (clockDay) clockDay.textContent = capitalize(dayText);
        if (clockTime) clockTime.textContent = hourText;
        if (clockSummary) {
          clockSummary.textContent = sample
            ? `${sample.description} · ${formatMapTemperature(sample.temperature)}`
            : "Prevision horaria";
        }
        stage?.classList.toggle("is-night", night);
        stage?.classList.toggle("is-day", !night);
      }

      function createMarkerIcon(place, point) {
        const markerPoint = point ?? createFramePoint(place, framePosition);
        const image = markerPoint?.image ?? place.forecast.current.image;
        const description = markerPoint?.description ?? place.forecast.current.description;
        const temperature = markerPoint?.temperature ?? place.forecast.current.temperature;
        const state = weatherStateForCode(markerPoint?.weatherCode ?? place.forecast.current.weatherCode);
        const temperatureClass = temperatureLevel(temperature);

        return L.divIcon({
          className: "weather-marker",
          html: markerHtml(place, image, description, temperature, state, temperatureClass),
          iconSize: [88, 56],
          iconAnchor: [44, 48],
          popupAnchor: [0, -44],
        });
      }

      function markerHtml(place, image, description, temperature, state, temperatureClass) {
        return `
          <div class="weather-marker__body weather-marker__body--${state} weather-marker__body--${temperatureClass}" title="${escapeHtml(place.city.name)}: ${escapeHtml(description)}" data-weather-marker>
            <img src="${image}" alt="" data-marker-icon />
            <strong class="weather-marker__temp weather-marker__temp--${temperatureClass}" data-marker-temp>${formatMapTemperature(temperature)}</strong>
            <span data-marker-city>${escapeHtml(place.city.name)}</span>
          </div>
        `;
      }

      function updateMarkerElement(place, point) {
        const markerBody = place.marker?.getElement()?.querySelector("[data-weather-marker]");
        if (!markerBody) {
          place.marker?.setIcon(createMarkerIcon(place, point));
          return;
        }

        const image = point?.image ?? place.forecast.current.image;
        const description = point?.description ?? place.forecast.current.description;
        const temperature = point?.temperature ?? place.forecast.current.temperature;
        const state = weatherStateForCode(point?.weatherCode ?? place.forecast.current.weatherCode);
        const temperatureClass = temperatureLevel(temperature);
        const icon = markerBody.querySelector("[data-marker-icon]");
        const temp = markerBody.querySelector("[data-marker-temp]");
        const city = markerBody.querySelector("[data-marker-city]");

        markerBody.className = `weather-marker__body weather-marker__body--${state} weather-marker__body--${temperatureClass}`;
        markerBody.setAttribute("title", `${place.city.name}: ${description}`);
        if (icon) icon.setAttribute("src", image);
        if (temp) {
          temp.textContent = formatMapTemperature(temperature);
          temp.className = `weather-marker__temp weather-marker__temp--${temperatureClass}`;
        }
        if (city) city.textContent = place.city.name;
      }

      function createPopup(place, point) {
        const description = point?.description ?? place.forecast.current.description;
        const temperature = point?.temperature ?? place.forecast.current.temperature;
        return `
          <strong>${escapeHtml(place.city.name)}</strong>
          <p>${escapeHtml(description)} · ${formatMapTemperature(temperature)}</p>
          <p>${point ? formatFullDate(point.time) : "Ahora"}</p>
          <p>Lluvia ${formatPercent(point?.rainProbability ?? place.forecast.today.precipitationProbability)} · Viento ${formatSpeed(point?.windSpeed ?? place.forecast.current.windSpeed)}</p>
          <p><a href="${place.city.href}">Ver detalle</a></p>
        `;
      }

      function renderCityList() {
        if (!list) return;
        list.innerHTML = places
          .map((place, index) => cityRowHtml(place, framePosition, index))
          .join("");
      }

      function updateMapListFrame(position) {
        const rows = list?.querySelectorAll("[data-map-row]");
        rows?.forEach((row) => {
          const place = places[Number(row.getAttribute("data-map-row"))];
          if (!place) return;
          const point = createFramePoint(place, position);
          const icon = row.querySelector("[data-row-icon]");
          const details = row.querySelector("[data-row-details]");
          const metrics = row.querySelector("[data-row-metrics]");
          if (icon) {
            icon.setAttribute("src", point?.image ?? place.forecast.current.image);
            icon.setAttribute("alt", point?.description ?? place.forecast.current.description);
          }
          if (details) {
            details.innerHTML = `
              <span>${point?.description ?? place.forecast.current.description}</span>
              <span>${point ? formatHour(point.time) : "Ahora"}</span>
            `;
          }
          if (metrics) {
            metrics.innerHTML = `
              <span>${formatMapTemperature(point?.temperature ?? place.forecast.current.temperature)}</span>
              <span>${formatPercent(point?.rainProbability ?? place.forecast.today.precipitationProbability)}</span>
              <span>${formatSpeed(point?.windSpeed ?? place.forecast.current.windSpeed)}</span>
            `;
          }
        });
      }

      function cityRowHtml(place, position, rowIndex) {
        const point = createFramePoint(place, position);
        return `
          <a class="weather-row" href="${place.city.href}" data-map-row="${rowIndex}">
            <img class="weather-icon weather-icon--sm" src="${point?.image ?? place.forecast.current.image}" alt="${point?.description ?? place.forecast.current.description}" loading="lazy" data-row-icon />
            <span>
              <span class="row__title">${escapeHtml(place.city.name)}</span>
              <span class="row__details" data-row-details>
                <span>${point?.description ?? place.forecast.current.description}</span>
                <span>${point ? formatHour(point.time) : "Ahora"}</span>
              </span>
            </span>
            <span class="row__metrics" data-row-metrics>
              <span>${formatMapTemperature(point?.temperature ?? place.forecast.current.temperature)}</span>
              <span>${formatPercent(point?.rainProbability ?? place.forecast.today.precipitationProbability)}</span>
              <span>${formatSpeed(point?.windSpeed ?? place.forecast.current.windSpeed)}</span>
            </span>
          </a>
        `;
      }

      function configureTimeline(frames) {
        frameCount = frames;
        framePosition = getInitialFramePosition();
        if (timeline) {
          timeline.min = "0";
          timeline.max = String(Math.max(frames - 1, 0));
          timeline.step = "0.01";
          timeline.value = String(framePosition);
          timeline.style.setProperty("--progress", getTimelineProgress(framePosition));
        }
      }

      function getFrameCount() {
        return Math.min(
          48,
          Math.max(0, ...places.map((place) => place.forecast.hourly?.length ?? 0)),
        );
      }

      function getInitialFramePosition() {
        const points = places[0]?.forecast?.hourly ?? [];
        if (!points.length) return 0;

        const now = getMadridNowMs();
        let nearestIndex = 0;
        let nearestDistance = Number.POSITIVE_INFINITY;

        for (let index = 0; index < Math.min(points.length, frameCount) - 1; index += 1) {
          const current = parseForecastTime(points[index]?.time);
          const next = parseForecastTime(points[index + 1]?.time);
          if (!Number.isFinite(current) || !Number.isFinite(next) || next <= current) continue;

          if (now >= current && now <= next) {
            return roundTimelineValue(index + (now - current) / (next - current));
          }

          const distance = Math.abs(now - current);
          if (distance < nearestDistance) {
            nearestDistance = distance;
            nearestIndex = index;
          }
        }

        const lastIndex = Math.min(points.length, frameCount) - 1;
        const lastDistance = Math.abs(now - parseForecastTime(points[lastIndex]?.time));
        return lastDistance < nearestDistance ? lastIndex : nearestIndex;
      }

      function createFramePoint(place, position) {
        const points = place?.forecast?.hourly ?? [];
        if (!points.length) return null;

        const lowerIndex = clamp(Math.floor(position), 0, points.length - 1);
        const upperIndex = clamp(Math.ceil(position), 0, points.length - 1);
        const lower = points[lowerIndex];
        const upper = points[upperIndex] ?? lower;
        const ratio = clamp(position - lowerIndex, 0, 1);
        const nearest = ratio < 0.5 ? lower : upper;

        return {
          ...nearest,
          time: interpolateTime(lower?.time, upper?.time, ratio),
          temperature: interpolateNumber(lower?.temperature, upper?.temperature, ratio),
          rainProbability: interpolateNumber(lower?.rainProbability, upper?.rainProbability, ratio),
          precipitation: interpolateNumber(lower?.precipitation, upper?.precipitation, ratio),
          windSpeed: interpolateNumber(lower?.windSpeed, upper?.windSpeed, ratio),
          windGusts: interpolateNumber(lower?.windGusts, upper?.windGusts, ratio),
        };
      }

      function fitMapToPlaces() {
        if (!map || places.length < 2) return;
        const bounds = L.latLngBounds(places.map((place) => [place.city.latitude, place.city.longitude]));
        map.fitBounds(bounds, { padding: [34, 34], maxZoom: region.zoom + 1 });
      }

      function setPlaying(nextPlaying) {
        playing = nextPlaying && frameCount > 1;
        if (playLabel) playLabel.textContent = playing ? "Pausa" : "Play";
        if (playIcon) playIcon.textContent = playing ? "⏸" : "▶";
        playButton?.setAttribute("aria-pressed", String(playing));
        window.cancelAnimationFrame(animationId);
        lastAnimationTime = 0;
        if (playing) {
          animationId = window.requestAnimationFrame(animate);
        }
      }

      function setControlsDisabled(disabled) {
        playButton?.toggleAttribute("disabled", disabled);
        timeline?.toggleAttribute("disabled", disabled);
      }

      function clearPlaces() {
        places.forEach((place) => place.marker?.remove());
        places = [];
        frameCount = 0;
        framePosition = 0;
      }

      function showMapError() {
        setPlaying(false);
        setControlsDisabled(true);
        if (status) status.textContent = "No se pudo cargar el mapa";
        if (list) {
          list.innerHTML = '<p class="state">No se pudo cargar el mapa. Revisa la conexion y vuelve a intentarlo.</p>';
        }
      }

      function getFavorites() {
        try {
          return JSON.parse(localStorage.getItem("extretiempo:favorites") ?? "[]");
        } catch (error) {
          return [];
        }
      }

      function formatFullDate(value) {
        if (!value) return "Ahora";
        return new Intl.DateTimeFormat("es-ES", {
          weekday: "short",
          day: "numeric",
          month: "short",
          hour: "2-digit",
          minute: "2-digit",
          timeZone: "Europe/Madrid",
        }).format(new Date(value));
      }

      function isNightFrame(point) {
        if (point?.image?.includes("n.png")) return true;
        const hour = Number(point?.time?.slice(11, 13));
        return Number.isFinite(hour) && (hour < 7 || hour >= 21);
      }

      function temperatureLevel(value) {
        if (value === null || value === undefined) return "mild";
        if (value <= 7) return "cold";
        if (value <= 14) return "cool";
        if (value >= 32) return "hot";
        if (value >= 26) return "warm";
        return "mild";
      }

      function formatMapTemperature(value) {
        if (value === null || value === undefined) return "--";
        return `${new Intl.NumberFormat("es-ES", { maximumFractionDigits: 1 }).format(value)}°`;
      }

      function interpolateNumber(start, end, ratio) {
        if (start === null || start === undefined) return end ?? null;
        if (end === null || end === undefined) return start;
        return start + (end - start) * ratio;
      }

      function interpolateTime(start, end, ratio) {
        if (!start || !end) return start ?? end ?? "";
        const startMs = parseForecastTime(start);
        const endMs = parseForecastTime(end);
        if (!Number.isFinite(startMs) || !Number.isFinite(endMs)) return start;
        return toLocalDateTimeString(new Date(startMs + (endMs - startMs) * ratio));
      }

      function parseForecastTime(value) {
        if (!value) return Number.NaN;
        return new Date(value).getTime();
      }

      function getMadridNowMs() {
        const parts = new Intl.DateTimeFormat("en-CA", {
          timeZone: "Europe/Madrid",
          year: "numeric",
          month: "2-digit",
          day: "2-digit",
          hour: "2-digit",
          minute: "2-digit",
          second: "2-digit",
          hour12: false,
        }).formatToParts(new Date());
        const values = Object.fromEntries(parts.map((part) => [part.type, part.value]));
        return new Date(`${values.year}-${values.month}-${values.day}T${values.hour}:${values.minute}:${values.second}`).getTime();
      }

      function toLocalDateTimeString(date) {
        const year = date.getFullYear();
        const month = pad(date.getMonth() + 1);
        const day = pad(date.getDate());
        const hour = pad(date.getHours());
        const minute = pad(date.getMinutes());
        const second = pad(date.getSeconds());
        return `${year}-${month}-${day}T${hour}:${minute}:${second}`;
      }

      function getTimelineProgress(position) {
        const maxFrame = Math.max(frameCount - 1, 0);
        return maxFrame <= 0 ? "0%" : `${(position / maxFrame) * 100}%`;
      }

      function roundTimelineValue(value) {
        return Math.round(value * TIMELINE_PRECISION) / TIMELINE_PRECISION;
      }

      function pad(value) {
        return String(value).padStart(2, "0");
      }

      function slugify(value) {
        return String(value)
          .normalize("NFD")
          .replace(/[\u0300-\u036f]/g, "")
          .toLowerCase()
          .replace(/[^a-z0-9]+/g, "-")
          .replace(/(^-|-$)/g, "");
      }

      function capitalize(value) {
        return value ? value.charAt(0).toUpperCase() + value.slice(1) : value;
      }

      function clamp(value, min, max) {
        return Math.min(Math.max(value, min), max);
      }

      function escapeHtml(value) {
        return String(value)
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }
    </script>
  </body>
</html>
