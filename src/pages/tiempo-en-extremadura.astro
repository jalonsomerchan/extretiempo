---
import { featuredLocations, locations } from "../data/locations";
import { insightPages } from "../data/insightPages";
import "../styles/global.css";

const siteUrl = "https://extretiempo.alon.one";
const title = "El tiempo en Extremadura hoy | ExtreTiempo";
const description = "Previsión meteorológica de Extremadura hoy: municipios de Cáceres y Badajoz, lluvia, calor, viento, heladas, polen, calidad del aire y mapas horarios.";
const canonical = `${siteUrl}/tiempo-en-extremadura/`;
const schema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "WebSite",
      name: "ExtreTiempo",
      url: siteUrl,
      inLanguage: "es-ES",
      potentialAction: {
        "@type": "SearchAction",
        target: `${siteUrl}/municipios/?q={search_term_string}`,
        "query-input": "required name=search_term_string",
      },
    },
    {
      "@type": "WebPage",
      name: title,
      description,
      url: canonical,
      inLanguage: "es-ES",
      about: [
        { "@type": "Place", name: "Extremadura" },
        { "@type": "Thing", name: "previsión meteorológica" },
      ],
      isPartOf: {
        "@type": "WebSite",
        name: "ExtreTiempo",
        url: siteUrl,
      },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Inicio", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "Tiempo en Extremadura", item: canonical },
      ],
    },
  ],
};
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="ExtreTiempo" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary" />
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body>
    <main class="app-shell insight-shell">
      <header class="site-header">
        <a class="brand brand--header" href="/" aria-label="ExtreTiempo inicio">
          <span class="brand__mark">ET</span>
          <span>
            <span class="eyebrow">Guía regional</span>
            <span class="brand__name">ExtreTiempo</span>
            <span class="meta">Tiempo en Extremadura</span>
          </span>
        </a>
        <nav class="site-header__actions" aria-label="Enlaces principales">
          <a class="link-button" href="/municipios/">Municipios</a>
          <a class="link-button" href="/mapas/extremadura/">Mapa</a>
        </nav>
      </header>

      <section class="insight-hero" aria-labelledby="extremadura-title">
        <div>
          <p class="eyebrow">Previsión local y regional</p>
          <h1 id="extremadura-title">El tiempo en Extremadura hoy</h1>
          <p>
            ExtreTiempo reúne previsión meteorológica por municipios de Extremadura con lectura rápida para Cáceres, Badajoz, Mérida, Plasencia, Piornal, Zafra, Don Benito y otras localidades. Consulta temperatura, lluvia, viento, UV, polen, calidad del aire, mapas horarios y rankings regionales.
          </p>
        </div>
        <div class="insight-hero__actions">
          <a class="chip" href="/hoy/">Resumen de hoy</a>
          <a class="chip" href="/mapas/extremadura/">Mapa animado</a>
          <a class="chip" href="/municipios/">Todos los municipios</a>
        </div>
      </section>

      <section class="section" aria-labelledby="que-consultar-title">
        <div class="section__header">
          <div>
            <p class="eyebrow">Búsquedas meteorológicas</p>
            <h2 class="section__title" id="que-consultar-title">Qué puedes consultar</h2>
            <p class="meta">Páginas preparadas para búsquedas reales: tiempo hoy, lluvia, calor, viento, heladas, polen y campo.</p>
          </div>
        </div>
        <div class="quick-grid">
          {insightPages.map((page) => (
            <a class="quick-card" href={`/${page.slug}/`}>
              <span class="brand__mark">{page.shortTitle.slice(0, 2).toUpperCase()}</span>
              <span class="quick-card__main">
                <span class="quick-card__title">{page.title}</span>
                <span class="meta">{page.subtitle}</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" aria-labelledby="localidades-title">
        <div class="section__header">
          <div>
            <p class="eyebrow">Localidades principales</p>
            <h2 class="section__title" id="localidades-title">Tiempo por localidad</h2>
            <p class="meta">Enlazado interno directo a fichas municipales para mejorar navegación y descubrimiento.</p>
          </div>
          <a class="chip" href="/municipios/">Ver todos</a>
        </div>
        <div class="quick-grid">
          {featuredLocations.map((location) => (
            <a class="quick-card" href={`/localidad/${location.slug}/`}>
              <span class="brand__mark">{location.name.slice(0, 2).toUpperCase()}</span>
              <span class="quick-card__main">
                <span class="quick-card__title">El tiempo en {location.name}</span>
                <span class="meta">Previsión por horas y próximos días</span>
              </span>
            </a>
          ))}
        </div>
      </section>

      <section class="section" aria-labelledby="provincias-title">
        <div class="section__header">
          <div>
            <p class="eyebrow">Arquitectura regional</p>
            <h2 class="section__title" id="provincias-title">Provincias y mapas</h2>
          </div>
        </div>
        <div class="chips">
          <a class="chip" href="/provincia/caceres/">El tiempo en la provincia de Cáceres</a>
          <a class="chip" href="/provincia/badajoz/">El tiempo en la provincia de Badajoz</a>
          <a class="chip" href="/mapas/caceres/">Mapa de Cáceres</a>
          <a class="chip" href="/mapas/badajoz/">Mapa de Badajoz</a>
          <a class="chip" href="/mapas/extremadura/">Mapa de Extremadura</a>
        </div>
      </section>

      <section class="section" aria-labelledby="fuentes-title">
        <div class="section__header">
          <div>
            <p class="eyebrow">Datos abiertos</p>
            <h2 class="section__title" id="fuentes-title">Fuentes meteorológicas</h2>
            <p class="meta">
              La previsión básica se apoya en Open-Meteo Forecast API. Las páginas de aire, polen, histórico, clima y ríos usan APIs libres relacionadas. Los datos son orientativos y no sustituyen avisos oficiales.
            </p>
          </div>
        </div>
        <div class="chips">
          <a class="chip" href="/calidad-del-aire/">Calidad del aire</a>
          <a class="chip" href="/historico/">Histórico reciente</a>
          <a class="chip" href="/clima-extremadura/">Clima y tendencia</a>
          <a class="chip" href="/rios/">Ríos y crecidas</a>
        </div>
      </section>

      <section class="section" aria-labelledby="info-title">
        <div class="section__header">
          <div>
            <p class="eyebrow">Transparencia</p>
            <h2 class="section__title" id="info-title">Información del proyecto</h2>
            <p class="meta">Páginas útiles para entender el proyecto, sus fuentes, límites, privacidad y vías de contacto.</p>
          </div>
        </div>
        <div class="chips">
          <a class="chip" href="/acerca-de/">Acerca de ExtreTiempo</a>
          <a class="chip" href="/mas-informacion/">Más información</a>
          <a class="chip" href="/contacto/">Contacto</a>
          <a class="chip" href="/privacidad/">Privacidad</a>
          <a class="chip" href="/aviso-legal/">Aviso legal</a>
        </div>
      </section>
    </main>

    <footer class="site-footer">
      <div>
        <strong>ExtreTiempo</strong>
        <p>Guía meteorológica regional para Extremadura con previsión municipal y mapas horarios.</p>
      </div>
      <nav aria-label="Enlaces de pie">
        <a href="/">Inicio</a>
        <a href="/municipios/">Municipios</a>
        <a href="/hoy/">Hoy</a>
        <a href="/rankings/">Rankings</a>
        <a href="/acerca-de/">Acerca de</a>
        <a href="/contacto/">Contacto</a>
      </nav>
    </footer>
  </body>
</html>
